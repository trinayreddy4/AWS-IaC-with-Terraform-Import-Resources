# Local .terraform directories
**/.terraform/*

# .tfstate files
# terraform.tfstate is intentionally tracked to persist import state
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
# *.tfvars
# *.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
tfplan
*.tfplan
